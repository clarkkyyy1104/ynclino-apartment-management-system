@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col-12">
        <h2 class="fw-bold text-primary">YNCLINO APARTMENT MANAGEMENT SYSTEM</h2>
        <p class="text-muted">Welcome to the admin dashboard. Use the menu to navigate.</p>
        <hr />
    </div>
</div>

<!-- Summary Cards -->
<div class="row g-4 mb-5">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 text-white bg-primary">
            <div class="card-body">
                <div class="small text-white-50">Total Units</div>
                <div class="display-6 fw-bold">@ViewBag.TotalUnits</div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <a asp-controller="Units" asp-action="Index" class="text-white small">View all units &rarr;</a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 text-white bg-success">
            <div class="card-body">
                <div class="small text-white-50">Vacant Units</div>
                <div class="display-6 fw-bold">@ViewBag.VacantUnits</div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <a asp-controller="Units" asp-action="Index" asp-route-statusFilter="Vacant" class="text-white small">View vacant &rarr;</a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 text-white bg-warning">
            <div class="card-body">
                <div class="small text-white-50">Occupied Units</div>
                <div class="display-6 fw-bold">@ViewBag.OccupiedUnits</div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <a asp-controller="Units" asp-action="Index" asp-route-statusFilter="Occupied" class="text-white small">View occupied &rarr;</a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 text-white bg-info">
            <div class="card-body">
                <div class="small text-white-50">Active Tenants</div>
                <div class="display-6 fw-bold">@ViewBag.ActiveTenants</div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <a asp-controller="Tenants" asp-action="Index" class="text-white small">View tenants &rarr;</a>
            </div>
        </div>
    </div>
</div>

<!-- Quick Links -->
<div class="row g-3">
    <div class="col-12">
        <h5 class="fw-semibold text-secondary">Quick Navigation</h5>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-light fw-semibold">Master File</div>
            <div class="list-group list-group-flush">
                <a asp-controller="Units" asp-action="Index" class="list-group-item list-group-item-action">
                    Units &mdash; Manage apartment units
                </a>
                <a asp-controller="Tenants" asp-action="Index" class="list-group-item list-group-item-action">
                    Tenants &mdash; Register &amp; manage tenants
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-light fw-semibold">Transactions</div>
            <div class="list-group list-group-flush">
                <a asp-controller="Billing" asp-action="Index" class="list-group-item list-group-item-action">
                    Billing &amp; Payment Monitoring
                </a>
                <a asp-controller="Maintenance" asp-action="Index" class="list-group-item list-group-item-action">
                    Maintenance Request
                </a>
                <a asp-controller="LostFound" asp-action="Index" class="list-group-item list-group-item-action">
                    Lost &amp; Found
                </a>
            </div>
        </div>
    </div>
</div>
