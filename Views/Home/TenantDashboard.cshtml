@model YnclinoAMS.Models.tblTenant?
@{
    ViewData["Title"] = "My Profile";
}

<div class="mb-4">
    <h4 class="fw-semibold mb-0">Welcome, @User.Identity?.Name</h4>
    <p class="text-muted small mb-0">Your current tenancy information is shown below.</p>
</div>

@if (Model == null)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="text-secondary mb-3" viewBox="0 0 16 16">
                <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
                <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1"/>
            </svg>
            <p class="fw-semibold mb-1 text-secondary">No tenant profile linked to your account.</p>
            <p class="small text-muted mb-0">Contact the administrator to link your account to a tenant record.</p>
        </div>
    </div>
}
else
{
    <div class="row g-3">

        <!-- Personal Info -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-primary text-white d-flex align-items-center gap-2 py-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
                    </svg>
                    <span class="fw-semibold small">Personal Information</span>
                </div>
                <div class="card-body pb-2">
                    <dl class="row mb-0 info-list">
                        <dt class="col-5">Full Name</dt>
                        <dd class="col-7">@Model.FullName</dd>

                        <dt class="col-5">Contact No.</dt>
                        <dd class="col-7">@(string.IsNullOrEmpty(Model.ContactNumber) ? "—" : Model.ContactNumber)</dd>

                        <dt class="col-5">Emergency Contact</dt>
                        <dd class="col-7">@(string.IsNullOrEmpty(Model.EmergencyContact) ? "—" : Model.EmergencyContact)</dd>

                        <dt class="col-5">Status</dt>
                        <dd class="col-7"><span class="badge bg-success">@Model.Status</span></dd>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Unit Info -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-info text-white d-flex align-items-center gap-2 py-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.707L2 8.207V13.5A1.5 1.5 0 0 0 3.5 15h9a1.5 1.5 0 0 0 1.5-1.5V8.207l.646.646a.5.5 0 0 0 .708-.707L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293zM13 7.207V13.5a.5.5 0 0 1-.5.5h-9a.5.5 0 0 1-.5-.5V7.207l5-5z"/>
                    </svg>
                    <span class="fw-semibold small">Unit Information</span>
                </div>
                <div class="card-body pb-2">
                    @if (Model.Unit != null)
                    {
                        <dl class="row mb-0 info-list">
                            <dt class="col-5">Unit Number</dt>
                            <dd class="col-7 fw-semibold">@Model.Unit.UnitNumber</dd>

                            <dt class="col-5">Unit Type</dt>
                            <dd class="col-7">@Model.Unit.UnitType</dd>

                            <dt class="col-5">Monthly Rent</dt>
                            <dd class="col-7">&#x20B1;@Model.Unit.RentPrice.ToString("N2")</dd>

                            <dt class="col-5">Capacity</dt>
                            <dd class="col-7">@Model.Unit.Capacity person(s)</dd>
                        </dl>
                    }
                    else
                    {
                        <p class="text-muted small mb-0">Unit information unavailable.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Lease Info -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-success text-white d-flex align-items-center gap-2 py-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z"/>
                    </svg>
                    <span class="fw-semibold small">Lease Details</span>
                </div>
                <div class="card-body pb-2">
                    <dl class="row mb-0 info-list">
                        <dt class="col-5">Move-In Date</dt>
                        <dd class="col-7">@(Model.MoveInDate?.ToString("MMM dd, yyyy") ?? "—")</dd>

                        <dt class="col-5">Lease Start</dt>
                        <dd class="col-7">@(Model.LeaseStart?.ToString("MMM dd, yyyy") ?? "—")</dd>

                        <dt class="col-5">Lease End</dt>
                        <dd class="col-7">
                            @if (Model.LeaseEnd.HasValue)
                            {
                                int daysLeft = (Model.LeaseEnd.Value - DateTime.Today).Days;
                                <span class="@(daysLeft < 30 ? "text-danger fw-semibold" : "")">
                                    @Model.LeaseEnd.Value.ToString("MMM dd, yyyy")
                                    @if (daysLeft >= 0)
                                    {
                                        <span class="text-muted small">(@daysLeft days left)</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger small">(expired)</span>
                                    }
                                </span>
                            }
                            else { <span>—</span> }
                        </dd>

                        <dt class="col-5">Date Recorded</dt>
                        <dd class="col-7">@Model.DateRecorded.ToString("MMM dd, yyyy")</dd>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Accessible Modules -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-secondary text-white d-flex align-items-center gap-2 py-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5zm8 0A1.5 1.5 0 0 1 10.5 1h3A1.5 1.5 0 0 1 15 2.5v3A1.5 1.5 0 0 1 13.5 7h-3A1.5 1.5 0 0 1 9 5.5zm-8 8A1.5 1.5 0 0 1 2.5 9h3A1.5 1.5 0 0 1 7 10.5v3A1.5 1.5 0 0 1 5.5 15h-3A1.5 1.5 0 0 1 1 13.5zm8 0A1.5 1.5 0 0 1 10.5 9h3A1.5 1.5 0 0 1 15 10.5v3A1.5 1.5 0 0 1 13.5 15h-3A1.5 1.5 0 0 1 9 13.5z"/>
                    </svg>
                    <span class="fw-semibold small">Available Modules</span>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-column gap-2">
                        <a asp-controller="Units" asp-action="Index" class="tenant-module-link d-flex align-items-center gap-2 text-decoration-none text-dark p-2 rounded">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="text-primary" viewBox="0 0 16 16">
                                <path d="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.707L2 8.207V13.5A1.5 1.5 0 0 0 3.5 15h9a1.5 1.5 0 0 0 1.5-1.5V8.207l.646.646a.5.5 0 0 0 .708-.707L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293zM13 7.207V13.5a.5.5 0 0 1-.5.5h-9a.5.5 0 0 1-.5-.5V7.207l5-5z"/>
                            </svg>
                            <span class="small">View Units</span>
                            <span class="badge bg-secondary ms-auto small">Read-only</span>
                        </a>
                        <a asp-controller="Billing" asp-action="Index" class="tenant-module-link d-flex align-items-center gap-2 text-decoration-none text-dark p-2 rounded">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="text-info" viewBox="0 0 16 16">
                                <path d="M4 10.781c.148 1.667 1.513 2.85 3.591 3.003V15h1.043v-1.216c2.27-.179 3.678-1.438 3.678-3.3 0-1.59-.947-2.51-2.956-3.028l-.722-.187V3.467c1.122.11 1.879.714 2.07 1.616h1.47c-.166-1.6-1.54-2.748-3.54-2.875V1H7.591v1.233c-1.939.23-3.27 1.472-3.27 3.156 0 1.454.966 2.483 2.661 2.917l.61.162v4.031c-1.149-.17-1.94-.8-2.131-1.718zm3.391-3.836c-1.043-.263-1.6-.825-1.6-1.616 0-.944.704-1.641 1.8-1.828v3.495l-.2-.05zm1.591 1.872c1.287.323 1.852.859 1.852 1.769 0 1.097-.826 1.828-2.2 1.939V8.73z"/>
                            </svg>
                            <span class="small">Billing &amp; Payment</span>
                            <span class="badge bg-secondary ms-auto small">Read-only</span>
                        </a>
                        <a asp-controller="Maintenance" asp-action="Index" class="tenant-module-link d-flex align-items-center gap-2 text-decoration-none text-dark p-2 rounded">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="text-warning" viewBox="0 0 16 16">
                                <path d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z"/>
                            </svg>
                            <span class="small">Maintenance Request</span>
                            <span class="badge bg-secondary ms-auto small">Read-only</span>
                        </a>
                        <a asp-controller="LostFound" asp-action="Index" class="tenant-module-link d-flex align-items-center gap-2 text-decoration-none text-dark p-2 rounded">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="text-secondary" viewBox="0 0 16 16">
                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
                            </svg>
                            <span class="small">Lost &amp; Found</span>
                            <span class="badge bg-secondary ms-auto small">Read-only</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>

    </div>
}
