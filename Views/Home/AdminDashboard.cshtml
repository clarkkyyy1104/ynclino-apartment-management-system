@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-4">
    <h4 class="fw-semibold mb-0">Welcome, @User.Identity?.Name</h4>
    <p class="text-muted small mb-0">You are logged in as Administrator. Full access is enabled.</p>
</div>

<div class="row g-3">

    <div class="col-12">
        <h6 class="section-label">Master File</h6>
    </div>

    <div class="col-sm-6 col-lg-4">
        <a asp-controller="Units" asp-action="Index" class="module-card card border-0 shadow-sm text-decoration-none">
            <div class="card-body d-flex align-items-start gap-3 p-4">
                <div class="module-icon bg-primary-subtle text-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.707L2 8.207V13.5A1.5 1.5 0 0 0 3.5 15h9a1.5 1.5 0 0 0 1.5-1.5V8.207l.646.646a.5.5 0 0 0 .708-.707L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293zM13 7.207V13.5a.5.5 0 0 1-.5.5h-9a.5.5 0 0 1-.5-.5V7.207l5-5z"/>
                    </svg>
                </div>
                <div>
                    <div class="module-title">Units</div>
                    <div class="module-desc">Manage apartment units, types, rent prices, and availability status.</div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-sm-6 col-lg-4">
        <a asp-controller="Tenants" asp-action="Index" class="module-card card border-0 shadow-sm text-decoration-none">
            <div class="card-body d-flex align-items-start gap-3 p-4">
                <div class="module-icon bg-success-subtle text-success">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
                    </svg>
                </div>
                <div>
                    <div class="module-title">Tenants</div>
                    <div class="module-desc">Register tenants, manage lease info, and track move-in/move-out records.</div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-12 mt-2">
        <h6 class="section-label">Transactions</h6>
    </div>

    <div class="col-sm-6 col-lg-4">
        <a asp-controller="Billing" asp-action="Index" class="module-card card border-0 shadow-sm text-decoration-none">
            <div class="card-body d-flex align-items-start gap-3 p-4">
                <div class="module-icon bg-info-subtle text-info">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M4 10.781c.148 1.667 1.513 2.85 3.591 3.003V15h1.043v-1.216c2.27-.179 3.678-1.438 3.678-3.3 0-1.59-.947-2.51-2.956-3.028l-.722-.187V3.467c1.122.11 1.879.714 2.07 1.616h1.47c-.166-1.6-1.54-2.748-3.54-2.875V1H7.591v1.233c-1.939.23-3.27 1.472-3.27 3.156 0 1.454.966 2.483 2.661 2.917l.61.162v4.031c-1.149-.17-1.94-.8-2.131-1.718zm3.391-3.836c-1.043-.263-1.6-.825-1.6-1.616 0-.944.704-1.641 1.8-1.828v3.495l-.2-.05zm1.591 1.872c1.287.323 1.852.859 1.852 1.769 0 1.097-.826 1.828-2.2 1.939V8.73z"/>
                    </svg>
                </div>
                <div>
                    <div class="module-title">Billing &amp; Payment</div>
                    <div class="module-desc">Monitor rent payments, billing cycles, and payment history.</div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-sm-6 col-lg-4">
        <a asp-controller="Maintenance" asp-action="Index" class="module-card card border-0 shadow-sm text-decoration-none">
            <div class="card-body d-flex align-items-start gap-3 p-4">
                <div class="module-icon bg-warning-subtle text-warning">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z"/>
                    </svg>
                </div>
                <div>
                    <div class="module-title">Maintenance Request</div>
                    <div class="module-desc">Track and manage unit repair and maintenance requests.</div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-sm-6 col-lg-4">
        <a asp-controller="LostFound" asp-action="Index" class="module-card card border-0 shadow-sm text-decoration-none">
            <div class="card-body d-flex align-items-start gap-3 p-4">
                <div class="module-icon bg-secondary-subtle text-secondary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
                    </svg>
                </div>
                <div>
                    <div class="module-title">Lost &amp; Found</div>
                    <div class="module-desc">Log and manage lost and found items reported within the premises.</div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-12 mt-2">
        <h6 class="section-label">Administration</h6>
    </div>

    <div class="col-sm-6 col-lg-4">
        <a asp-controller="Users" asp-action="Index" class="module-card card border-0 shadow-sm text-decoration-none">
            <div class="card-body d-flex align-items-start gap-3 p-4">
                <div class="module-icon bg-danger-subtle text-danger">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
                        <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1"/>
                    </svg>
                </div>
                <div>
                    <div class="module-title">User Accounts</div>
                    <div class="module-desc">Create and manage system accounts for admins and tenants.</div>
                </div>
            </div>
        </a>
    </div>

</div>
