@model YnclinoAMS.Models.ViewModels.TenantViewModel
@{
    ViewData["Title"] = "Register Tenant";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white fw-semibold">Register New Tenant</div>
            <div class="card-body">
                <form asp-action="Create" method="post" id="tenantForm">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <!-- Account Credentials -->
                    <h6 class="section-label mb-3">Login Account</h6>

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label fw-semibold small"></label>
                        <input asp-for="Username" class="form-control" autocomplete="username" placeholder="Tenant's login username" />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>

                    <div class="mb-2">
                        <label asp-for="Password" class="form-label fw-semibold small"></label>
                        <div class="pw-wrapper">
                            <input asp-for="Password" id="pw" class="form-control pe-5" autocomplete="new-password" oninput="checkStrength(this.value)" />
                            <button type="button" class="pw-toggle" onclick="togglePw('pw')" tabindex="-1">
                                @Html.Raw(EyeIcon("pw"))
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <ul class="pw-rules list-unstyled small mb-3 ps-1" id="pwRules">
                        <li id="r-len"><span class="rule-icon"></span> At least 8 characters</li>
                        <li id="r-upper"><span class="rule-icon"></span> At least one uppercase letter</li>
                        <li id="r-lower"><span class="rule-icon"></span> At least one lowercase letter</li>
                        <li id="r-digit"><span class="rule-icon"></span> At least one number</li>
                        <li id="r-special"><span class="rule-icon"></span> At least one special character (!&#64;#$%^&amp;*)</li>
                    </ul>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold small"></label>
                        <div class="pw-wrapper">
                            <input asp-for="ConfirmPassword" id="cpw" class="form-control pe-5" autocomplete="new-password" />
                            <button type="button" class="pw-toggle" onclick="togglePw('cpw')" tabindex="-1">
                                @Html.Raw(EyeIcon("cpw"))
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <!-- Tenant Profile -->
                    <h6 class="section-label mb-3">Tenant Profile</h6>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label fw-semibold small"></label>
                            <input asp-for="FirstName" class="form-control" placeholder="First name" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label fw-semibold small"></label>
                            <input asp-for="LastName" class="form-control" placeholder="Last name" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="UnitID" class="form-label fw-semibold small"></label>
                        <select asp-for="UnitID" asp-items="Model.AvailableUnits" class="form-select">
                            <option value="">— Select Unit —</option>
                        </select>
                        <span asp-validation-for="UnitID" class="text-danger small"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="ContactNumber" class="form-label fw-semibold small"></label>
                            <input asp-for="ContactNumber" class="form-control" placeholder="e.g. 09XX-XXX-XXXX" />
                            <span asp-validation-for="ContactNumber" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EmergencyContact" class="form-label fw-semibold small"></label>
                            <input asp-for="EmergencyContact" class="form-control" placeholder="Name — Number" />
                            <span asp-validation-for="EmergencyContact" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="MoveInDate" class="form-label fw-semibold small"></label>
                            <input asp-for="MoveInDate" class="form-control" type="date" />
                            <span asp-validation-for="MoveInDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MoveOutDate" class="form-label fw-semibold small"></label>
                            <input asp-for="MoveOutDate" class="form-control" type="date" />
                            <span asp-validation-for="MoveOutDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="LeaseStart" class="form-label fw-semibold small"></label>
                            <input asp-for="LeaseStart" class="form-control" type="date" />
                            <span asp-validation-for="LeaseStart" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LeaseEnd" class="form-label fw-semibold small"></label>
                            <input asp-for="LeaseEnd" class="form-control" type="date" />
                            <span asp-validation-for="LeaseEnd" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-sm">Register Tenant</button>
                        <a asp-action="Index" class="btn btn-secondary btn-sm">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/password.js" asp-append-version="true"></script>
    <script>
        document.getElementById('tenantForm').addEventListener('submit', function (e) {
            var pw = document.getElementById('pw').value;
            if (!meetsAllRules(pw)) {
                e.preventDefault();
                document.getElementById('pwRules').classList.add('shake');
                setTimeout(() => document.getElementById('pwRules').classList.remove('shake'), 600);
            }
        });
    </script>
}

@functions {
    string EyeIcon(string id) => $@"
        <svg id=""{id}-eye"" xmlns=""http://www.w3.org/2000/svg"" width=""18"" height=""18"" fill=""currentColor"" viewBox=""0 0 16 16"">
            <path d=""M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z""/>
            <path d=""M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0""/>
        </svg>
        <svg id=""{id}-eye-slash"" xmlns=""http://www.w3.org/2000/svg"" width=""18"" height=""18"" fill=""currentColor"" viewBox=""0 0 16 16"" style=""display:none"">
            <path d=""M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7 7 0 0 0-2.79.588l.77.771A6 6 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755q-.247.248-.517.486z""/>
            <path d=""M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829z""/>
            <path d=""M3.35 5.47q-.27.24-.518.487A13 13 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7 7 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12z""/>
        </svg>";
}
