<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Ynclino AMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                Ynclino AMS
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav me-auto align-items-lg-center">

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <!-- Master File group -->
                        <li class="nav-item">
                            <span class="nav-label">Master File</span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-sub" asp-controller="Units" asp-action="Index">Units</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-sub" asp-controller="Tenants" asp-action="Index">Tenants</a>
                        </li>

                        <li class="nav-item nav-divider d-none d-lg-block"></li>

                        <!-- Transactions group -->
                        <li class="nav-item">
                            <span class="nav-label">Transactions</span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-sub" asp-controller="Billing" asp-action="Index">Billing &amp; Payment</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-sub" asp-controller="Maintenance" asp-action="Index">Maintenance</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-sub" asp-controller="LostFound" asp-action="Index">Lost &amp; Found</a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item nav-divider d-none d-lg-block"></li>

                            <!-- Admin group -->
                            <li class="nav-item">
                                <span class="nav-label">Admin</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-sub" asp-controller="Users" asp-action="Index">User Accounts</a>
                            </li>
                        }
                    }

                </ul>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        <li class="nav-item me-2">
                            <span class="navbar-text text-white-50 small">
                                @User.Identity.Name
                                <span class="badge @(User.IsInRole("Admin") ? "bg-danger" : "bg-secondary") ms-1">
                                    @(User.IsInRole("Admin") ? "Admin" : "Tenant")
                                </span>
                            </span>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-light">Sign Out</button>
                            </form>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </nav>

    <div class="container-fluid py-4 px-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <footer class="border-top py-3 text-center text-muted small">
        &copy; @DateTime.Now.Year &mdash; Ynclino Apartment Management System
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
