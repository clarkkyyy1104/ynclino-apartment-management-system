@model YnclinoAMS.Models.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Ynclino AMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #f0f2f5;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        .login-card {
            width: 100%;
            max-width: 400px;
            border: none;
            border-radius: 10px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.10);
        }
        .login-header {
            background-color: #0d6efd;
            color: #fff;
            border-radius: 10px 10px 0 0;
            padding: 1.75rem 1.5rem 1.5rem;
            text-align: center;
        }
        .login-header .brand-icon {
            width: 44px;
            height: 44px;
            background: rgba(255,255,255,0.15);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 0.75rem;
        }
        .login-header h5 {
            margin: 0;
            font-weight: 700;
            letter-spacing: .3px;
        }
        .login-header p {
            margin: .2rem 0 0;
            font-size: .82rem;
            opacity: .8;
        }
        .pw-wrapper {
            position: relative;
        }
        .pw-toggle {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            padding: 2px 4px;
            color: #6c757d;
            cursor: pointer;
            line-height: 1;
        }
        .pw-toggle:hover { color: #343a40; }
    </style>
</head>
<body>
    <div class="login-card card">
        <div class="login-header">
            <div class="brand-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="white" viewBox="0 0 16 16">
                    <path d="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.707L2 8.207V13.5A1.5 1.5 0 0 0 3.5 15h9a1.5 1.5 0 0 0 1.5-1.5V8.207l.646.646a.5.5 0 0 0 .708-.707L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293zM13 7.207V13.5a.5.5 0 0 1-.5.5h-9a.5.5 0 0 1-.5-.5V7.207l5-5z"/>
                </svg>
            </div>
            <h5>Ynclino AMS</h5>
            <p>Apartment Management System</p>
        </div>
        <div class="card-body p-4">
            <form asp-action="Login" method="post">
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 small mb-3">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="Username" class="form-label fw-semibold small"></label>
                    <input asp-for="Username" class="form-control" autofocus autocomplete="username" />
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label fw-semibold small"></label>
                    <div class="pw-wrapper">
                        <input asp-for="Password" id="loginPassword" class="form-control pe-5" autocomplete="current-password" />
                        <button type="button" class="pw-toggle" onclick="togglePassword('loginPassword', this)" tabindex="-1" aria-label="Show/hide password">
                            <svg id="loginPassword-eye" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z"/>
                                <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0"/>
                            </svg>
                            <svg id="loginPassword-eye-slash" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16" style="display:none">
                                <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7 7 0 0 0-2.79.588l.77.771A6 6 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755q-.247.248-.517.486z"/>
                                <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829z"/>
                                <path d="M3.35 5.47q-.27.24-.518.487A13 13 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7 7 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12z"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 fw-semibold">Sign In</button>
            </form>
        </div>
        <div class="card-footer text-center text-muted small py-2">
            &copy; @DateTime.Now.Year Ynclino Apartment Management System
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function togglePassword(inputId, btn) {
            var input = document.getElementById(inputId);
            var eye = document.getElementById(inputId + '-eye');
            var slash = document.getElementById(inputId + '-eye-slash');
            if (input.type === 'password') {
                input.type = 'text';
                eye.style.display = 'none';
                slash.style.display = '';
            } else {
                input.type = 'password';
                eye.style.display = '';
                slash.style.display = 'none';
            }
        }
    </script>
</body>
</html>
