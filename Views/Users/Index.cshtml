@model IEnumerable<YnclinoAMS.Models.tblUser>
@{
    ViewData["Title"] = "User Accounts";
    bool isSuperAdmin = ViewBag.IsSuperAdmin == true;
    bool isAdmin = ViewBag.IsAdmin == true;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">User Accounts</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">Add Account</a>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-hover table-sm align-middle">
        <thead class="table-light">
            <tr>
                <th>#</th>
                <th>Username</th>
                <th>Role</th>
                <th>Status</th>
                <th>Date Created</th>
                <th style="width:140px">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.UserID</td>
                    <td>
                        @user.Username
                        @if (user.IsSuperAdmin)
                        {
                            <span class="badge bg-danger ms-1" title="Super Admin — undeletable">
                                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/>
                                </svg>
                                Super Admin
                            </span>
                        }
                    </td>
                    <td>
                        @{
                            var badgeClass = user.Role switch {
                                "Admin"     => "bg-danger",
                                "SemiAdmin" => "bg-warning text-dark",
                                _           => "bg-secondary"
                            };
                            var roleLabel = user.Role == "SemiAdmin" ? "Semi-Admin" : user.Role;
                        }
                        <span class="badge @badgeClass">@roleLabel</span>
                    </td>
                    <td>
                        <span class="badge @(user.IsActive ? "bg-success" : "bg-warning text-dark")">
                            @(user.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td>@user.DateCreated.ToString("MM/dd/yyyy")</td>
                    <td>
                        @{
                            bool canEdit = isAdmin || user.Role == "Tenant";
                            bool canDelete = !user.IsSuperAdmin && (isAdmin || user.Role == "Tenant");
                        }
                        @if (canEdit)
                        {
                            <a asp-action="Edit" asp-route-id="@user.UserID" class="btn btn-outline-secondary btn-sm">Edit</a>
                        }
                        @if (canDelete)
                        {
                            <a asp-action="Delete" asp-route-id="@user.UserID" class="btn btn-outline-danger btn-sm">Delete</a>
                        }
                        @if (!canEdit && !canDelete)
                        {
                            <span class="text-muted small">—</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <p class="text-muted text-center py-4">No accounts found.</p>
}
