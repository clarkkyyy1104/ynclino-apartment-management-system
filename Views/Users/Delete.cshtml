@model YnclinoAMS.Models.tblUser
@{
    ViewData["Title"] = "Delete Account";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">Delete Account</h5>
            </div>
            <div class="card-body">
                <p>Are you sure you want to permanently delete this account?</p>

                <dl class="row mb-4">
                    <dt class="col-sm-4">Username</dt>
                    <dd class="col-sm-8">@Model.Username</dd>
                    <dt class="col-sm-4">Role</dt>
                    <dd class="col-sm-8">@Model.Role</dd>
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">@(Model.IsActive ? "Active" : "Inactive")</dd>
                    <dt class="col-sm-4">Created</dt>
                    <dd class="col-sm-8">@Model.DateCreated.ToString("MM/dd/yyyy")</dd>
                </dl>

                <div class="alert alert-warning py-2 small">
                    Any tenants linked to this account will have their account link cleared (the tenant record itself is preserved).
                </div>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.UserID" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">Yes, Delete</button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
