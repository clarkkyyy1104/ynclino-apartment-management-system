@model YnclinoAMS.Models.tblUnit
@{
    ViewData["Title"] = "Delete Unit";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white fw-semibold">Confirm Delete</div>
            <div class="card-body">
                <p class="text-danger fw-semibold">Are you sure you want to permanently delete this unit?</p>

                <dl class="row">
                    <dt class="col-sm-4">Unit Number</dt>
                    <dd class="col-sm-8">@Model.UnitNumber</dd>
                    <dt class="col-sm-4">Unit Type</dt>
                    <dd class="col-sm-8">@Model.UnitType</dd>
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">@Model.Status</dd>
                </dl>

                @if (Model.Tenants != null && Model.Tenants.Any(t => t.Status == "Active"))
                {
                    <div class="alert alert-warning">
                        This unit has active tenants and cannot be deleted.
                    </div>
                }

                <form asp-action="Delete" method="post">
                    <input type="hidden" name="id" value="@Model.UnitID" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">Yes, Delete</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
