@model YnclinoAMS.Models.ViewModels.UnitViewModel
@{
    ViewData["Title"] = "Add Unit";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white fw-semibold">Add New Unit</div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none"></div>

                    <div class="mb-3">
                        <label asp-for="UnitNumber" class="form-label fw-semibold"></label>
                        <input asp-for="UnitNumber" class="form-control" placeholder="e.g. 101" />
                        <span asp-validation-for="UnitNumber" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="UnitType" class="form-label fw-semibold"></label>
                        <select asp-for="UnitType" class="form-select">
                            <option value="">— Select Unit Type —</option>
                            <option>Studio</option>
                            <option>1-Bedroom</option>
                            <option>2-Bedroom</option>
                            <option>3-Bedroom</option>
                        </select>
                        <span asp-validation-for="UnitType" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="RentPrice" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text">₱</span>
                            <input asp-for="RentPrice" class="form-control" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="RentPrice" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Capacity" class="form-label fw-semibold"></label>
                        <input asp-for="Capacity" class="form-control" placeholder="e.g. 2" />
                        <span asp-validation-for="Capacity" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Status" class="form-label fw-semibold"></label>
                        <select asp-for="Status" class="form-select">
                            <option>Vacant</option>
                            <option>Occupied</option>
                            <option>Under Maintenance</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save Unit</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
