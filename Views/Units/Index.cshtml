@model IEnumerable<YnclinoAMS.Models.tblUnit>
@{
    ViewData["Title"] = "Units";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="fw-bold mb-0">Units</h3>
    <a asp-action="Create" class="btn btn-primary">+ Add Unit</a>
</div>

<!-- Filters -->
<form method="get" class="row g-2 mb-4">
    <div class="col-auto">
        <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" class="form-control"
               placeholder="Search unit number or type…" />
    </div>
    <div class="col-auto">
        <select name="statusFilter" class="form-select">
            <option value="">All Statuses</option>
            <option value="Vacant" selected="@(ViewBag.StatusFilter == "Vacant")">Vacant</option>
            <option value="Occupied" selected="@(ViewBag.StatusFilter == "Occupied")">Occupied</option>
            <option value="Under Maintenance" selected="@(ViewBag.StatusFilter == "Under Maintenance")">Under Maintenance</option>
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">Filter</button>
        <a asp-action="Index" class="btn btn-link">Clear</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-primary">
            <tr>
                <th>Unit Number</th>
                <th>Unit Type</th>
                <th>Rent Price</th>
                <th>Capacity</th>
                <th>Status</th>
                <th>Date Added</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var unit in Model)
            {
                <tr>
                    <td class="fw-semibold">@unit.UnitNumber</td>
                    <td>@unit.UnitType</td>
                    <td>₱@unit.RentPrice.ToString("N2")</td>
                    <td>@unit.Capacity</td>
                    <td>
                        @{
                            var badge = unit.Status switch {
                                "Occupied" => "bg-warning text-dark",
                                "Vacant" => "bg-success",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @badge">@unit.Status</span>
                    </td>
                    <td>@unit.DateAdded.ToString("MMM dd, yyyy")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@unit.UnitID" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@unit.UnitID" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">No units found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
