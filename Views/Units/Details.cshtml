@model YnclinoAMS.Models.tblUnit
@{
    ViewData["Title"] = $"Unit {Model.UnitNumber}";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-info text-white fw-semibold">Unit Details — @Model.UnitNumber</div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Unit Number</dt>
                    <dd class="col-sm-8">@Model.UnitNumber</dd>

                    <dt class="col-sm-4">Unit Type</dt>
                    <dd class="col-sm-8">@Model.UnitType</dd>

                    <dt class="col-sm-4">Rent Price</dt>
                    <dd class="col-sm-8">₱@Model.RentPrice.ToString("N2")</dd>

                    <dt class="col-sm-4">Capacity</dt>
                    <dd class="col-sm-8">@Model.Capacity person(s)</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        @{
                            var badge = Model.Status switch {
                                "Occupied" => "bg-warning text-dark",
                                "Vacant" => "bg-success",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @badge">@Model.Status</span>
                    </dd>

                    <dt class="col-sm-4">Date Added</dt>
                    <dd class="col-sm-8">@Model.DateAdded.ToString("MMMM dd, yyyy")</dd>
                </dl>

                @if (Model.Tenants != null && Model.Tenants.Any())
                {
                    <h6 class="fw-semibold mt-3">Current Tenants</h6>
                    <ul class="list-group">
                        @foreach (var t in Model.Tenants.Where(t => t.Status == "Active"))
                        {
                            <li class="list-group-item">@t.FirstName @t.LastName</li>
                        }
                    </ul>
                }
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.UnitID" class="btn btn-primary btn-sm">Edit</a>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to List</a>
            </div>
        </div>
    </div>
</div>
